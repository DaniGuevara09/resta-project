generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Invoice {
  id        String   @id @default(uuid())
  orderId   String
  total     Float
  status    InvoiceStatus @default(PENDING)
  createdAt DateTime @default(now())
}

enum InvoiceStatus {
  PENDING
  PAID
}