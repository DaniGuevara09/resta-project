npm-debug.log*
yarn-error.log*

# --- BACKEND NODE.JS ---
/backend-node/node_modules/
/backend-node/dist/

# --- BACKEND PYTHON ---
# Entornos virtuales
venv/
.venv/
env/
# Archivos compilados de Python
__pycache__/
*.py[cod]
*$py.class

# --- INFRAESTRUCTURA (Docker, Kafka, DB) ---
*/data/
*/db-data/
*.db
*.sqlite3

# --- SISTEMA Y EDITORES ---
