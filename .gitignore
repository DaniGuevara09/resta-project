# --- SEGURIDAD (Separación de Política y Mecanismo) ---
.env
*.pem
*.key

# --- FRONTEND (Angular) ---
# Carpeta de dependencias
/resta-frontend/node_modules/
# Archivos de compilación
/resta-frontend/dist/
/resta-frontend/.angular/
